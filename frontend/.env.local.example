# ============================================================
# LOGIQ Frontend — Environment Variables
# Copy to .env.local (Next.js auto-loads this file in dev).
# NEVER commit .env.local to version control.
# ============================================================

# Backend API base URL — no trailing slash
# Only NEXT_PUBLIC_ prefixed variables are exposed to the browser bundle.
NEXT_PUBLIC_API_URL=http://localhost:8000/api   # local only: http://localhost:8000/api
                                                # server only: injected by docker-compose as http://backend:8000/api
