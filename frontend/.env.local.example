# ============================================================
# LOGIQ Frontend — Environment Variables
# Copy to .env.local (Next.js auto-loads this file in dev).
# In Docker, NEXT_PUBLIC_API_URL is injected at BUILD TIME via
# the docker-compose build arg — this file is for local dev only.
# NEVER commit .env.local to version control.
# ============================================================

# Backend API base URL — no trailing slash.
# Only NEXT_PUBLIC_ prefixed variables are exposed to the browser bundle.
# IMPORTANT: Next.js bakes this value into the JS bundle at build time.
# For Docker/production use, set it in the root .env and rebuild the image.
NEXT_PUBLIC_API_URL=http://localhost:8000/api
