# Databases
PLATFORM_DB_NAME=logiq_platform
PLATFORM_DB_USER=logiq_platform_user
PLATFORM_DB_PASSWORD=logiq_platform_password
PLATFORM_DB_HOST=localhost
PLATFORM_DB_PORT=5432

WAREHOUSE_DB_NAME=logiq_warehouse
WAREHOUSE_DB_USER=logiq_warehouse_user
WAREHOUSE_DB_PASSWORD=logiq_warehouse_password
