# ============================================================
# LOGIQ — Root Environment Variables Template
# Consumed by docker-compose.yml for ${VAR} substitution.
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# ── Platform DB (Django ORM — logiq_platform) ───────────────────────────────
PLATFORM_DB_NAME=logiq_platform               # local + server
PLATFORM_DB_USER=logiq_platform_user          # local + server
PLATFORM_DB_PASSWORD=logiq_platform_password  # local + server (use strong password in production)

# ── Warehouse DB (analytical — logiq_warehouse) ─────────────────────────────
WAREHOUSE_DB_NAME=logiq_warehouse             # local + server
WAREHOUSE_DB_USER=logiq_warehouse_user        # local + server
WAREHOUSE_DB_PASSWORD=logiq_warehouse_password # local + server (use strong password in production)

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-dev-secret-key-change-in-production  # local + server (use strong random key in production)
# Comma-separated list of allowed hosts for the Django backend.
# server: must include the public domain and VPS IP
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1     # local only
# DJANGO_ALLOWED_HOSTS=logiq.space,www.logiq.space,93.127.162.203  # server only

# ── Superadmin (created by: docker compose exec backend python manage.py create_superadmin) ─
SUPERADMIN_USERNAME=admin                     # local + server
SUPERADMIN_EMAIL=admin@logiq.space            # local + server
SUPERADMIN_PASSWORD=admin                     # local only (use strong password in production)

# ── Frontend → Backend URL ────────────────────────────────────────────────────
# IMPORTANT: this variable is baked into the Next.js JS bundle at BUILD TIME.
# After changing it, rebuild the frontend image: docker compose up --build -d frontend
# local only: http://localhost:8000/api
# server only: https://logiq.space/api  (the public URL — browsers cannot reach http://backend:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ── Source system API credentials (used by Dagster ETL + Backend sync) ───────
# These are mock credentials — any non-empty value is accepted by the mock server.
API_BASE_URL=http://localhost:8001            # local only: http://localhost:8001
# API_BASE_URL=http://mock-datasources:8000  # set automatically in docker-compose for server
YALIDINE_API_ID=mock-api-id                  # local + server
YALIDINE_API_TOKEN=mock-api-token            # local + server
HRFORCE_API_TOKEN=mock-token                 # local + server
CASHBOX_API_TOKEN=mock-token                 # local + server
PAIE_API_TOKEN=mock-token                    # local + server
TRANSPORT_API_TOKEN=mock-token               # local + server

# ── Dagster ↔ Django webhook shared secret ───────────────────────────────────
# Set the same value in dagster/.env and here. Leave empty to disable verification in dev.
DAGSTER_WEBHOOK_TOKEN=                        # local only: leave empty
# DAGSTER_WEBHOOK_TOKEN=<generate: python3 -c "import secrets; print(secrets.token_hex(32))">  # server only

# ── Local-only vars (not substituted by docker-compose) ──────────────────────
# These are only used when running services directly outside Docker.
PLATFORM_DB_HOST=localhost                    # local only (Docker uses: platform-db)
PLATFORM_DB_PORT=5433                         # local only (Docker internal: 5432)
WAREHOUSE_DB_HOST=localhost                   # local only (Docker uses: warehouse-db)
WAREHOUSE_DB_PORT=5433                        # local only (Docker internal: 5432)
REDIS_URL=redis://localhost:6379/0            # local only (Docker uses: redis://redis:6379/0)
DJANGO_SETTINGS_MODULE=config.settings.dev   # local only (Docker uses: config.settings.prod)
DEBUG=True                                    # local only (Docker uses: False)

# ── Email (ETL/alert notification channel) ───────────────────────────────────
# Passed into the backend and celery containers by docker-compose.
# local only: leave EMAIL_BACKEND as console — emails print to stdout, no SMTP needed.
# server only: switch to smtp and provide real credentials.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend  # local only
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend   # server only
EMAIL_HOST=smtp.gmail.com                     # local + server
EMAIL_PORT=587                                # local + server
EMAIL_USE_TLS=true                            # local + server
EMAIL_HOST_USER=                              # server only: SMTP login (e.g. your@gmail.com)
EMAIL_HOST_PASSWORD=                          # server only: app password / SMTP secret
DEFAULT_FROM_EMAIL=LOGIQ Platform <noreply@logiq.space>  # local + server
