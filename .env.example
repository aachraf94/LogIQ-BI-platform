# ============================================================
# LOGIQ — Root Environment Variables Template
# Used by docker-compose.yml and shared across all services.
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Platform DB (Django ORM — logiq_platform) ---
PLATFORM_DB_NAME=logiq_platform               # local + server
PLATFORM_DB_USER=logiq_platform_user          # local + server
PLATFORM_DB_PASSWORD=logiq_platform_password  # local + server (change in production)
PLATFORM_DB_HOST=localhost                    # local only: localhost  |  server only: platform-db (Docker service name)
PLATFORM_DB_PORT=5433                         # local only: 5433       |  server only: 5432 (Docker internal port)

# --- Warehouse DB (analytical — logiq_warehouse) ---
WAREHOUSE_DB_NAME=logiq_warehouse             # local + server
WAREHOUSE_DB_USER=logiq_warehouse_user        # local + server
WAREHOUSE_DB_PASSWORD=logiq_warehouse_password # local + server (change in production)
WAREHOUSE_DB_HOST=localhost                   # local only: localhost  |  server only: warehouse-db (Docker service name)
WAREHOUSE_DB_PORT=5433                        # local only: 5433       |  server only: 5432 (Docker internal port)

# --- Redis ---
REDIS_URL=redis://localhost:6379/0            # local only: redis://localhost:6379/0
                                              # server only: redis://redis:6379/0

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev   # local only: config.settings.dev
                                              # server only: config.settings.prod
SECRET_KEY=your-dev-secret-key-change-in-production  # local + server (use a strong random key in production)
DEBUG=True                                    # local only: True  |  server only: False
ALLOWED_HOSTS=localhost,127.0.0.1             # local only  |  server only: add your server IP/domain

# --- Next.js ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api # local only: http://localhost:8000/api
                                              # server only: http://backend:8000/api (Docker internal)
