# ============================================================
# LOGIQ Backend — Environment Variables Template
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.dev

# --- Superadmin (used by: python manage.py create_superadmin) ---
SUPERADMIN_USERNAME=admin
SUPERADMIN_EMAIL=admin@logiq.com
SUPERADMIN_PASSWORD=admin

# --- Platform DB (Django ORM) ---
PLATFORM_DB_NAME=logiq_platform
PLATFORM_DB_USER=logiq_platform_user
PLATFORM_DB_PASSWORD=logiq_platform_password
PLATFORM_DB_HOST=localhost
PLATFORM_DB_PORT=5432

# --- Warehouse DB (analytical, read by analytics app) ---
WAREHOUSE_DB_NAME=logiq_warehouse
WAREHOUSE_DB_USER=logiq_warehouse_user
WAREHOUSE_DB_PASSWORD=logiq_warehouse_password
WAREHOUSE_DB_HOST=localhost
WAREHOUSE_DB_PORT=5433

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0

# --- HRForce API (used by sync_hrforce_users management command) ---
API_BASE_URL=http://localhost:8000
HRFORCE_API_TOKEN=mock-token

# --- Dagster ETL webhook (shared secret, set the same value in Dagster) ---
# Leave empty to disable webhook token verification during development.
DAGSTER_WEBHOOK_TOKEN=
