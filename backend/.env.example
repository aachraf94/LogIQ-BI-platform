# ============================================================
# LOGIQ Backend — Environment Variables Template
# Copy to .env and fill in real values before running.
# In Docker, all vars below are set by docker-compose.yml — this
# file is only needed for local (venv) development.
# NEVER commit .env to version control.
# ============================================================

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string          # local + server (use strong random key in production)
DJANGO_SETTINGS_MODULE=config.settings.dev            # local only: config.settings.dev
                                                      # server only: config.settings.prod (set in docker-compose)
DEBUG=True                                            # local only: True
                                                      # server only: False (prod settings hardcode this)

# Comma-separated allowed hosts. Must include the public domain in production.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1              # local only
# DJANGO_ALLOWED_HOSTS=logiq.space,www.logiq.space,93.127.162.203  # server only

# ── Superadmin (used by: python manage.py create_superadmin) ─────────────────
SUPERADMIN_USERNAME=admin                             # local + server
SUPERADMIN_EMAIL=admin@logiq.space                    # local + server
SUPERADMIN_PASSWORD=admin                             # local only (use strong password in production)

# ── Platform DB (Django ORM — logiq_platform) ────────────────────────────────
PLATFORM_DB_NAME=logiq_platform                       # local + server
PLATFORM_DB_USER=logiq_platform_user                  # local + server
PLATFORM_DB_PASSWORD=logiq_platform_password          # local + server (use strong password in production)
PLATFORM_DB_HOST=localhost                            # local only: localhost
                                                      # server only: platform-db (set in docker-compose)
PLATFORM_DB_PORT=5433                                 # local only: 5433 (single PG instance on non-standard port)
                                                      # server only: 5432 (set in docker-compose)

# ── Warehouse DB (analytical — logiq_warehouse) ──────────────────────────────
WAREHOUSE_DB_NAME=logiq_warehouse                     # local + server
WAREHOUSE_DB_USER=logiq_warehouse_user                # local + server
WAREHOUSE_DB_PASSWORD=logiq_warehouse_password        # local + server (use strong password in production)
WAREHOUSE_DB_HOST=localhost                           # local only: localhost
                                                      # server only: warehouse-db (set in docker-compose)
WAREHOUSE_DB_PORT=5433                                # local only: 5433
                                                      # server only: 5432 (set in docker-compose)

# ── Redis (Celery broker + result backend) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0                    # local only: redis://localhost:6379/0
                                                      # server only: redis://redis:6379/0 (set in docker-compose)

# ── Source system API (used by sync_hrforce_users management command) ─────────
API_BASE_URL=http://localhost:8001                    # local only: http://localhost:8001 (mock-datasources on 8001)
                                                      # server only: http://mock-datasources:8000 (set in docker-compose)
HRFORCE_API_TOKEN=mock-token                          # local + server (any non-empty value for mock)

# ── Dagster ETL webhook (shared secret — set the same value in dagster/.env) ──
# Leave empty to disable webhook token verification during development.
DAGSTER_WEBHOOK_TOKEN=                                # local only: leave empty
                                                      # server only: set a shared random secret
