# ============================================================
# LOGIQ Backend — Environment Variables Template
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string          # local + server (use a strong random key in production)
DJANGO_SETTINGS_MODULE=config.settings.dev            # local only: config.settings.dev
                                                      # server only: config.settings.prod (set in docker-compose)

# --- Superadmin (used by: python manage.py create_superadmin) ---
SUPERADMIN_USERNAME=admin                             # local + server
SUPERADMIN_EMAIL=admin@logiq.com                      # local + server
SUPERADMIN_PASSWORD=admin                             # local + server (change in production)

# --- Platform DB (Django ORM — logiq_platform) ---
PLATFORM_DB_NAME=logiq_platform                       # local + server
PLATFORM_DB_USER=logiq_platform_user                  # local + server
PLATFORM_DB_PASSWORD=logiq_platform_password          # local + server (change in production)
PLATFORM_DB_HOST=localhost                            # local only: localhost
                                                      # server only: platform-db (Docker service name, set in compose)
PLATFORM_DB_PORT=5433                                 # local only: 5433 (single PG instance on non-standard port)
                                                      # server only: 5432 (Docker internal, set in compose)

# --- Warehouse DB (analytical — logiq_warehouse) ---
WAREHOUSE_DB_NAME=logiq_warehouse                     # local + server
WAREHOUSE_DB_USER=logiq_warehouse_user                # local + server
WAREHOUSE_DB_PASSWORD=logiq_warehouse_password        # local + server (change in production)
WAREHOUSE_DB_HOST=localhost                           # local only: localhost
                                                      # server only: warehouse-db (Docker service name, set in compose)
WAREHOUSE_DB_PORT=5433                                # local only: 5433 (same PG instance, different database)
                                                      # server only: 5432 (Docker internal, set in compose)

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://localhost:6379/0                    # local only: redis://localhost:6379/0
                                                      # server only: redis://redis:6379/0 (set in compose)

# --- HRForce API (used by sync_hrforce_users management command) ---
API_BASE_URL=http://localhost:8001                    # local only: http://localhost:8001 (mock-datasources on 8001)
                                                      # server only: http://mock-datasources:8000 (Docker service name)
HRFORCE_API_TOKEN=mock-token                          # local + server (use real token in production)

# --- Dagster ETL webhook (shared secret — set the same value in dagster/.env) ---
# Leave empty to disable webhook token verification during development.
DAGSTER_WEBHOOK_TOKEN=                                # local only: leave empty
                                                      # server only: set a shared random secret
