# ============================================================
# LOGIQ Dagster — Environment Variables Template
# Copy to .env and fill in real values before running.
# In Docker, all vars below are set by docker-compose.yml — this
# file is only needed for local (venv) development.
# NEVER commit .env to version control.
# ============================================================

# ── Base URL for all source system APIs ──────────────────────────────────────
# All five API clients share the same host (mock-datasources).
API_BASE_URL=http://localhost:8001   # local only: http://localhost:8001 (mock-datasources on port 8001)
                                     # server only: http://mock-datasources:8000 (set in docker-compose)

# ── Yalidine API credentials ──────────────────────────────────────────────────
YALIDINE_API_ID=mock-api-id          # local + server (any non-empty value for mock)
YALIDINE_API_TOKEN=mock-api-token    # local + server (any non-empty value for mock)

# ── HRForce API ───────────────────────────────────────────────────────────────
HRFORCE_API_TOKEN=mock-token         # local + server

# ── Cash Box API ──────────────────────────────────────────────────────────────
CASHBOX_API_TOKEN=mock-token         # local + server

# ── PC Paie (Payroll) API ─────────────────────────────────────────────────────
PAIE_API_TOKEN=mock-token            # local + server

# ── Dedicated Transport API ───────────────────────────────────────────────────
TRANSPORT_API_TOKEN=mock-token       # local + server

# ── Django backend URL (for ETL run status webhook) ──────────────────────────
BACKEND_URL=http://localhost:8000    # local only: http://localhost:8000
                                     # server only: http://backend:8000 (set in docker-compose)

# ── Dagster ETL webhook (shared secret — set the same value in backend/.env) ──
DAGSTER_WEBHOOK_TOKEN=               # local only: leave empty
                                     # server only: set in docker-compose

# ── Warehouse PostgreSQL ──────────────────────────────────────────────────────
WAREHOUSE_DB_HOST=localhost          # local only: localhost
                                     # server only: warehouse-db (set in docker-compose)
WAREHOUSE_DB_PORT=5433               # local only: 5433 (single PG instance on non-standard port)
                                     # server only: 5432 (set in docker-compose)
WAREHOUSE_DB_NAME=logiq_warehouse    # local + server
WAREHOUSE_DB_USER=logiq_warehouse_user   # local + server
WAREHOUSE_DB_PASSWORD=logiq_warehouse_password  # local + server (use strong password in production)

# ── Dagster home directory ────────────────────────────────────────────────────
# Must point to the directory containing dagster.yaml.
# local only: set to the absolute path of logiq/dagster/dagster_home on your machine
# server only: /app/dagster_home (set automatically in Dockerfile via ENV DAGSTER_HOME)
DAGSTER_HOME=/absolute/path/to/logiq/dagster/dagster_home

# ── Windows-only: enable compute log capture in the terminal ─────────────────
# Remove or leave unset on Linux/macOS and inside Docker.
# PYTHONLEGACYWINDOWSSTDIO=1
