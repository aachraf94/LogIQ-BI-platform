# ============================================================
# LOGIQ Dagster — Environment Variables Template
# Copy to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Shared API base URL (all internal APIs share the same host) ---
API_BASE_URL=http://localhost:8000

# --- Yalidine API ---
YALIDINE_API_ID=your_yalidine_api_id
YALIDINE_API_TOKEN=your_yalidine_api_token

# --- HRForce API ---
HRFORCE_API_TOKEN=your_hrforce_api_token

# --- CashBox API ---
CASHBOX_API_TOKEN=your_cashbox_api_token

# --- Paie (Payroll) API ---
PAIE_API_TOKEN=your_paie_api_token

# --- Transport API ---
TRANSPORT_API_TOKEN=your_transport_api_token

# --- Warehouse PostgreSQL ---
WAREHOUSE_DB_HOST=localhost
WAREHOUSE_DB_PORT=5433
WAREHOUSE_DB_NAME=logiq_warehouse
WAREHOUSE_DB_USER=logiq_warehouse_user
WAREHOUSE_DB_PASSWORD=your_db_password

# --- Dagster home (optional, defaults to ~/.dagster) ---
# DAGSTER_HOME=/path/to/dagster/home
